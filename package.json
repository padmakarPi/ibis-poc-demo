{
  "name": "vplatform-frontend-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max_old_space_size=8192 && set NEXT_PRIVATE_LOCAL_WEBPACK=true && next dev",
    "build": "set NODE_OPTIONS=--max_old_space_size=8192 && set NEXT_PRIVATE_LOCAL_WEBPACK=true && next build",
    "start": "npm run update-css-client && next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --check --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .prettierignore .",
    "prepare": "husky",
    "check-unused": "node check-unused.js",
    "update-css-client": "node scripts/replace-client-id-in-css.js"
  },
  "dependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@module-federation/nextjs-mf": "^8.8.23",
    "@mui/icons-material": "^7.3.4",
    "@mui/joy": "^5.0.0-beta.52",
    "@mui/material": "^7.3.4",
    "@mui/system": "^7.3.3",
    "@mui/x-date-pickers": "^7.22.3",
    "@reduxjs/toolkit": "^2.9.0",
    "@sentry/nextjs": "^10.5.0",
    "@vplatform/core": "^1.0.2",
    "axios": "^1.12.0",
    "babel-loader": "^10.0.0",
    "cors": "^2.8.5",
    "css-loader": "^6.11.0",
    "dayjs": "^1.11.11",
    "depcheck": "^1.4.7",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "next": "^15.5.7",
    "oidc-client": "^1.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^5.0.0",
    "react-highlight-words": "^0.21.0",
    "react-hook-form": "^7.47.0",
    "react-icons": "^4.11.0",
    "react-infinite-scroll-component": "^6.1.1",
    "react-player": "^3.4.0",
    "react-redux": "^9.2.0",
    "react-toastify": "^10.0.6",
    "redux-persist": "^6.0.0",
    "sass-loader": "^14.2.1",
    "style-loader": "^4.0.0",
    "styled-components": "^6.1.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/js-cookie": "^3.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "dotenv": "^16.4.7",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-next": "^15.0.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "3.0.3",
    "ts-node": "^10.9.2"
  },
  "overrides": {
    "koa": "3.0.3",
    "esbuild": "0.25.0",
    "brace-expansion": "1.1.12"
  }
}
