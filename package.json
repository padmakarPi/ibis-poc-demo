{
  "name": "vplatform-frontend-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max_old_space_size=8192 && set NEXT_PRIVATE_LOCAL_WEBPACK=true && next dev",
    "build": "npm run update-css-client && set NODE_OPTIONS=--max_old_space_size=8192 && set NEXT_PRIVATE_LOCAL_WEBPACK=true && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --check --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .prettierignore .",
    "prepare": "husky",
    "check-unused": "node check-unused.js",
    "update-css-client": "node scripts/replace-client-id-in-css.js"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@module-federation/nextjs-mf": "^8.3.16",
    "@mui/icons-material": "^5.15.8",
    "@mui/joy": "^5.0.0-beta.8",
    "@mui/material": "^5.15.7",
    "@mui/system": "^5.15.9",
    "@mui/x-date-pickers": "^6.16.0",
    "@reduxjs/toolkit": "^1.9.6",
    "@vplatform/shared-components": "^1.2.12",
    "axios": "^1.5.1",
    "css-loader": "^6.11.0",
    "dayjs": "^1.11.11",
    "depcheck": "^1.4.7",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "next": "^14.2.26",
    "oidc-client": "^1.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^5.0.0",
    "react-highlight-words": "^0.20.0",
    "react-hook-form": "^7.47.0",
    "react-icons": "^4.11.0",
    "react-redux": "^8.1.3",
    "react-toastify": "^10.0.6",
    "redux-persist": "^6.0.0",
    "sass-loader": "^14.2.1",
    "style-loader": "^4.0.0",
    "styled-components": "^6.1.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "dotenv": "^16.4.7",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-next": "^15.0.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "3.0.3",
    "ts-node": "^10.9.2"
  },
  "overrides": {
    "koa": "2.16.1",
    "esbuild": "0.25.0"
  }
}
