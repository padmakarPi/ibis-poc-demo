{
  "name": "vplatform-frontend-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max_old_space_size=8192 && set NEXT_PRIVATE_LOCAL_WEBPACK=true && next dev",
    "build": "set NODE_OPTIONS=--max_old_space_size=8192 && set NEXT_PRIVATE_LOCAL_WEBPACK=true && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --check --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .prettierignore .",
    "prepare": "husky install",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "check-unused": "node check-unused.js"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.16.7",
    "@mui/material": "^5.16.0",
    "@mui/x-date-pickers": "^6.16.0",
    "@reduxjs/toolkit": "^1.9.6",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@vplatform/shared-components": "^1.6.55",
    "axios": "^1.5.1",
    "css-loader": "^6.11.0",
    "dayjs": "^1.11.10",
    "depcheck": "^1.4.7",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "next": "^14.2.18",
    "oidc-client": "^1.11.5",
    "qs": "^6.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-highlight-words": "^0.20.0",
    "react-hook-form": "^7.47.0",
    "react-icons": "^4.11.0",
    "react-redux": "^8.1.3",
    "redux-persist": "^6.0.0",
    "sass": "^1.69.5",
    "sass-loader": "^14.2.1",
    "style-loader": "^4.0.0",
    "styled-components": "^6.1.8",
    "webpack": "^5.91.0"
  },
  "devDependencies": {
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/js-cookie": "^3.0.4",
    "@types/node": "latest",
    "@types/qs": "^6.9.8",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/react-highlight-words": "^0.16.5",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "^8.52.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-next": "13.4.8",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest-dom": "^5.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-testing-library": "^6.2.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "3.0.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
